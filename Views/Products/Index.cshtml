@model IEnumerable<Lab2OPP.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Products</h2>
    <a asp-action="Create" class="btn btn-success">Create Product</a>
</div>

<table class="table table-hover table-bordered align-middle">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Category</th>
            <th class="text-end">Price</th>
            <th class="text-end">Quantity</th>
            <th style="width: 220px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Id</td>
                <td>@p.Name</td>
                <td>@p.Category</td>
                <td class="text-end">@p.Price</td>
                <td class="text-end">@p.Quantity</td>
                <td>
                    <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-outline-secondary btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-outline-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>