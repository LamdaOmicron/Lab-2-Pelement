@{
    ViewData["Title"] = "Home";
}

<div class="p-4 p-md-5 mb-4 bg-light rounded-3 border">
    <div class="container-fluid py-2">
        <h1 class="display-6 fw-bold">Order Management System</h1>
        <p class="col-md-10 fs-5">
            This application helps you manage users, products, orders, and order items.
            Use the navigation menu to open the required section.
        </p>

        <div class="mt-3 d-flex flex-wrap gap-2">
            <a class="btn btn-success" asp-controller="Users" asp-action="Index">Open Users</a>
            <a class="btn btn-primary" asp-controller="Products" asp-action="Index">Open Products</a>
            <a class="btn btn-outline-dark" asp-controller="Orders" asp-action="Index">Open Orders</a>
            <a class="btn btn-outline-secondary" asp-controller="OrderItems" asp-action="Index">Open Order Items</a>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="border rounded-3 p-3 bg-white">
            <h5 class="mb-2">Workflow</h5>
            <ol class="mb-0">
                <li>Create at least one user</li>
                <li>Create at least one product</li>
                <li>Create an order and select the user</li>
                <li>Add order items (order + product + quantity)</li>
            </ol>
        </div>
    </div>

    <div class="col-md-6">
        <div class="border rounded-3 p-3 bg-white">
            <h5 class="mb-2">Notes</h5>
            <ul class="mb-0">
                <li>All pages support CRUD operations</li>
                <li>Orders reference users</li>
                <li>Order items reference both orders and products</li>
            </ul>
        </div>
    </div>
</div>