@model Lab2OPP.Models.OrderItem

@{
    ViewData["Title"] = "Delete Order Item";
}

<h2>Delete Order Item</h2>
<hr />

<div class="alert alert-warning">
    Are you sure you want to delete this item?
</div>

<dl class="row">
    <dt class="col-sm-2">Order</dt>
    <dd class="col-sm-10">Order #@Model.OrderId</dd>

    <dt class="col-sm-2">Product</dt>
    <dd class="col-sm-10">@Model.Product?.Name</dd>

    <dt class="col-sm-2">Quantity</dt>
    <dd class="col-sm-10">@Model.Quantity</dd>
</dl>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>