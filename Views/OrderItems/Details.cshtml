@model Lab2OPP.Models.OrderItem

@{
    ViewData["Title"] = "Order Item Details";
}

<h2>Order Item Details</h2>
<hr />

<dl class="row">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">Order</dt>
    <dd class="col-sm-10">Order #@Model.OrderId</dd>

    <dt class="col-sm-2">Product</dt>
    <dd class="col-sm-10">@Model.Product?.Name</dd>

    <dt class="col-sm-2">Quantity</dt>
    <dd class="col-sm-10">@Model.Quantity</dd>
</dl>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>